{
  "manifest_version": 3,
  "name": "AmtAssist",
  "version": "0.1.0",
  "description": "AI assistance for German forms",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
